<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutHolder"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/brain_gain_background"
    android:padding="14dp">

    <!-- Header (icon + name) -->
    <LinearLayout
        android:id="@+id/topHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/monkeyLadderHeaderIcon"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:contentDescription="Monkey Ladder"
            android:src="@drawable/monkey_ladder_icon"
            app:tint="@color/colorPrimaryDark" />

        <TextView
            android:id="@+id/textViewGameName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:includeFontPadding="false"
            android:text="Monkey Ladder"
            android:textColor="@color/colorPrimaryDark"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Stats row (match Token Search style) -->
    <LinearLayout
        android:id="@+id/statsRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topHeader">

        <!-- Score box -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/dnb_stat_circle_bg"
            android:minHeight="68dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/scoreHeaderText"
                    android:src="@drawable/trophy_icon"
                    app:tint="@color/colorPrimaryDark" />

                <TextView
                    android:id="@+id/score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/score"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Lives box -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/dnb_stat_circle_bg"
            android:minHeight="68dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/livesHeaderText"
                    android:src="@drawable/ml_heart"
                    app:tint="@color/colorPrimaryDark" />

                <TextView
                    android:id="@+id/livesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="3"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Level box -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/dnb_stat_circle_bg"
            android:minHeight="68dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@string/levelHeaderText"
                    android:src="@drawable/level_icon"
                    app:tint="@color/colorPrimaryDark" />

                <TextView
                    android:id="@+id/levelText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="1"
                    android:textColor="@color/colorPrimaryDark"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/userSelectionResult"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone" />

    <!-- Board -->
    <FrameLayout
        android:id="@+id/boardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="12dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsRow"
        app:layout_constraintDimensionRatio="5:4">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alignmentMode="alignMargins"
            android:columnCount="5"
            android:rowCount="4"
            android:useDefaultMargins="false">

            <ImageView android:id="@+id/text_00" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="0" android:layout_columnWeight="1" android:layout_row="0" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_01" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="1" android:layout_columnWeight="1" android:layout_row="0" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_02" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="2" android:layout_columnWeight="1" android:layout_row="0" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_03" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="3" android:layout_columnWeight="1" android:layout_row="0" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_04" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="4" android:layout_columnWeight="1" android:layout_row="0" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />

            <ImageView android:id="@+id/text_10" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="0" android:layout_columnWeight="1" android:layout_row="1" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_11" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="1" android:layout_columnWeight="1" android:layout_row="1" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_12" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="2" android:layout_columnWeight="1" android:layout_row="1" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_13" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="3" android:layout_columnWeight="1" android:layout_row="1" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_14" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="4" android:layout_columnWeight="1" android:layout_row="1" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />

            <ImageView android:id="@+id/text_20" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="0" android:layout_columnWeight="1" android:layout_row="2" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_21" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="1" android:layout_columnWeight="1" android:layout_row="2" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_22" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="2" android:layout_columnWeight="1" android:layout_row="2" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_23" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="3" android:layout_columnWeight="1" android:layout_row="2" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_24" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="4" android:layout_columnWeight="1" android:layout_row="2" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />

            <ImageView android:id="@+id/text_30" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="0" android:layout_columnWeight="1" android:layout_row="3" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_31" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="1" android:layout_columnWeight="1" android:layout_row="3" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_32" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="2" android:layout_columnWeight="1" android:layout_row="3" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_33" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="3" android:layout_columnWeight="1" android:layout_row="3" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />
            <ImageView android:id="@+id/text_34" android:layout_width="0dp" android:layout_height="0dp" android:layout_column="4" android:layout_columnWeight="1" android:layout_row="3" android:layout_rowWeight="1" android:layout_margin="6dp" android:background="@drawable/monkey_ladder_cell_display" android:onClick="onClick" android:scaleType="fitCenter" android:src="@drawable/monkey_ladder_transparent" />

        </GridLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
